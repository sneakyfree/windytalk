# Copy to .env and fill in. Only OPENAI_API_KEY is required.
OPENAI_API_KEY=sk-proj-...

# Optional overrides:
# JARVIS_MODEL=gpt-realtime-2.1-mini   # or gpt-realtime-2.1 (best) / gpt-realtime (GA)
# JARVIS_VOICE=cedar                   # cedar / marin / alloy / echo / shimmer
# JARVIS_ALLOW_DANGEROUS=0             # 1 = disable the shell-command safety denylist
# JARVIS_PROMPT="You are Windy..."     # override the persona/system prompt
