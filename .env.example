# Copy to .env and fill in the brain you want. You only need a key for the
# provider you actually use (default provider is "gemini").

# Which brain to start with: gemini | openai
JARVIS_PROVIDER=gemini

# --- Google Gemini Live (free key: https://aistudio.google.com/apikey) -------
GOOGLE_API_KEY=

# --- OpenAI Realtime (key: https://platform.openai.com/api-keys) -------------
OPENAI_API_KEY=

# Optional overrides:
# JARVIS_GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# JARVIS_GEMINI_VOICE=Puck            # Puck / Charon / Kore / Fenrir / Aoede
# JARVIS_OPENAI_MODEL=gpt-realtime-2.1-mini
# JARVIS_OPENAI_VOICE=cedar
# JARVIS_ALLOW_DANGEROUS=0            # 1 = disable the shell-command safety denylist
# JARVIS_PROMPT="You are Windy..."    # override the persona/system prompt
