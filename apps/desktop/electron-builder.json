{
  "appId": "ai.windstorm.windytalk",
  "productName": "WindyTalk",
  "directories": {
    "output": "release"
  },
  "files": [
    "electron/**/*",
    "dist/electron/**/*",
    "renderer/**/*",
    "!dist/test/**"
  ],
  "extraResources": [
    {
      "from": "payload/current",
      "to": "payload"
    }
  ],
  "npmRebuild": false,
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "category": "Utility",
    "maintainer": "Windstorm Labs LLC",
    "artifactName": "windytalk-${version}-linux-x86_64.${ext}"
  },
  "win": {
    "target": [
      "nsis"
    ],
    "artifactName": "windytalk-${version}-win-x64.${ext}"
  },
  "nsis": {
    "oneClick": true,
    "deleteAppDataOnUninstall": false
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": [
          "universal"
        ]
      }
    ],
    "category": "public.app-category.utilities",
    "artifactName": "windytalk-${version}-mac-universal.${ext}",
    "x64ArchFiles": "{**/payload/**,**/payload/**/.*/**}"
  }
}